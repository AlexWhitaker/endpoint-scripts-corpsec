# Environment variables used by scripts in this repo.
# Copy to .env and fill in values; never commit .env.

# ── Nessus Agent deployment ────────────────────────────────────
TENABLE_LINKING_KEY=                # From Tenable → Sensors → Agent Linking
NESSUS_AGENT_DMG=                   # e.g. NessusAgent-10.6.1.dmg
NESSUS_AGENT_PKG=                   # e.g. NessusAgent-10.6.1.pkg
